    "url": "https://github.com/braynexservices/nigeria-mcp/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "nigeria",
    "imf",
    "weo",
    "macroeconomics",
    "projections",
    "economy"
  ],
  "private": false,
  "publishConfig": {
