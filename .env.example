# Nigeria MCP — environment example.
# Copy to `.env` (git-ignored) and fill only what you need.
# Defaults run EVERYTHING on free mock providers with zero signup.

# ---- Provider selection (per lane) ----
BANK_PROVIDER=mock         # mock | paystack
FX_PROVIDER=mock           # mock | free
ELECTRICITY_PROVIDER=mock  # mock | vtpass      (LIVE — read-only meter validation)
TRADE_PROVIDER=mock        # mock | opendata    (LIVE — UN Comtrade + HS classify)

# ---- Free-lane provider selection (all keyless; live needs no API key) ----
BOUNDARY_PROVIDER=mock          # mock | grid3      (LIVE — GRID3 admin boundaries)
ADMIN_DIVISIONS_PROVIDER=static # static only        (offline bundled 37 states / 774 LGAs)
HEALTH_PROVIDER=mock            # mock | grid3      (LIVE — GRID3 health facilities)
MACRO_PROVIDER=mock             # mock | worldbank  (LIVE — World Bank indicators)
IMF_PROVIDER=mock               # mock | imf        (LIVE — IMF WEO DataMapper)
SDG_PROVIDER=mock               # mock | unsdg      (LIVE — UN SDG Global Database)
CRYPTO_PROVIDER=mock            # mock | quidax     (LIVE — Quidax tickers, read-only)
SANCTIONS_PROVIDER=nigsac       # nigsac (LIVE, default) | mock (offline synthetic stub)

# ---- Provider credentials (only for live providers; never commit real values) ----
# Required when BANK_PROVIDER=paystack (free Paystack secret key)
PAYSTACK_SECRET_KEY=

# Required when ELECTRICITY_PROVIDER=vtpass (free VTpass sandbox keys)
VTPASS_API_KEY=
VTPASS_PUBLIC_KEY=
VTPASS_SECRET_KEY=
# VTPASS_BASE_URL=https://vtpass.com/api   # production (default = sandbox)

# ---- HTTP transport (shared/src/http.ts; stateless, Bearer auth) ----
# Comma-separated API keys the HTTP server will accept. Empty = stdio-only use.

# ---- Cache ----
